{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JoseRFJuniorLLMs/Micelio/schemas/intent.schema.json",
  "title": "AIP INTENT Payload",
  "description": "Payload for INTENT messages — requesting a capability",
  "type": "object",
  "required": ["capability", "description"],
  "properties": {
    "capability": {
      "type": "string",
      "description": "Namespaced capability identifier (e.g., 'nlp.translate')"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of what is needed"
    },
    "params": {
      "type": "object",
      "description": "Capability-specific parameters"
    },
    "budget": {
      "type": "object",
      "properties": {
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string" }
      },
      "required": ["amount", "currency"]
    },
    "deadline": {
      "type": "string",
      "format": "date-time"
    }
  }
}
